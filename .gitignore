build/
flutter_*.png
# pubspec.lock is committed: this is an app, not a library, so we want
# reproducible dependency resolution. Do NOT ignore it.

# Third-party web SQLite assets (drift worker + sqlite3 wasm). Library
# artifacts, not our source — fetched by tool/fetch_web_db_assets.* and in the
# Docker build. Keeping them out of git avoids scanning vendored code.
web/drift_worker.js
web/sqlite3.wasm

