<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup & transfer rules. cloud-backup covers Auto
  Backup to the user's Google account (US-11.5); device-transfer covers
  phone-to-phone migration. Both include the drift database and shared prefs.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
