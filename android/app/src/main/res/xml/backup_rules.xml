<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API <= 31). Backs up the FeatherLog data to the
  user's own Google account so a reinstall / new phone restores their history
  at no cost to the project (US-11.5, DATA_MODEL.md §1). drift stores the
  database under the app's databases/ directory.
-->
<full-backup-content>
    <include domain="database" path="." />
    <include domain="sharedpref" path="." />
</full-backup-content>
